{
  "crons": [
    {
      "path": "/api/cron/refresh",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/__dump_cache/:source.csv",
      "destination": "/api/dump-cache/:source"
    },
    {
      "source": "/__ios_performance_dump_health",
      "destination": "/api/dump-health"
    }
  ]
}
